# Kopiere diese Datei zu `.env` und trage deine Werte ein.
# Die echte .env NICHT ins Git-Repo committen (steht in .gitignore).

# Deine Domain, die auf den Server zeigt (A-Record im DNS).
DOMAIN=shamela.deine-domain.de

# Geheimer Zugangs-Token für die App. Selbst ausdenken – lang & zufällig.
# Beispiel erzeugen:  openssl rand -hex 32
API_TOKEN=hier-einen-langen-zufaelligen-token-eintragen

# Optional: Hugging-Face-Token, nur falls beim Download ein Limit auftritt.
HF_TOKEN=
